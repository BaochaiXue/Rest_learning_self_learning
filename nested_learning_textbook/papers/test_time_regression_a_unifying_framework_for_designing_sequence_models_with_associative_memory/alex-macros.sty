% Theorem envs - [section] means counter resets after each section
% [theorem] means that same counter as theorem is used
% [section] means we start with the section counter
\newtheorem{mytheorem}{Theorem}[section]
\newtheorem*{theorem*}{Theorem}

\newtheorem{lemma}[mytheorem]{Lemma}
\newtheorem*{lemma*}{Lemma}

\newtheorem{proposition}[mytheorem]{Proposition}
\newtheorem*{proposition*}{Proposition}

\newtheorem{corollary}[mytheorem]{Corollary}
\newtheorem*{corollary*}{Corollary}

\newtheorem{definition}{Definition}[section]
\newtheorem*{definition*}{Definition}

% Remarks, claims do not use extra space or italic text
{\theoremstyle{remark}
\newtheorem{claim}{Claim}
\newtheorem{remark}{Remark}
\newtheorem{example}{Example}
\newtheorem{exercise}{Exercise}[section]
}

